# Example environment file for Cloud Functions
# Copy to .env or .env.local in this directory (both are gitignored).
# Firebase CLI loads these for deploy and emulator. See: https://firebase.google.com/docs/functions/config-env

# Required for aiProxy and chat worker (Gemini)
GEMINI_API_KEY=your-api-key-here

# Optional: Path B chat (production should set and rotate this)
# CHAT_UID_HMAC_SECRET=your-hmac-secret

# Optional: enqueueTask uses these if set (otherwise from project config)
# GCLOUD_PROJECT=your-project-id
# CHAT_WORKER_URL_US_CENTRAL1=https://...
