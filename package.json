{
  "name": "novachat",
  "version": "1.0.0",
  "description": "NovaChat is a modern Android AI chatbot application that supports online (cloud-based) AI models. Offline (on-device) mode is planned but currently unavailable because AICore is not yet published to Maven. Built with the latest Android technologies targeting Android 16.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "format": "npm exec -- prettier --write \"**/*.{json,js,ts}\"",
    "format:check": "npm exec -- prettier --check \"**/*.{json,js,ts}\"",
    "android:setup-sdk": "bash ./scripts/ensure-android-sdk.sh",
    "android:setup-google-services": "bash ./scripts/ensure-google-services.sh",
    "git:clear-stale-locks": "bash ./scripts/clear-stale-git-locks.sh",
    "editor:extensions:sync": "bash ./scripts/ensure-editor-extensions.sh",
    "android:prepare": "npm run git:clear-stale-locks && npm run android:setup-sdk && npm run android:setup-google-services",
    "cursor:mcp:docker:build": "bash ./scripts/ensure-cursor-mcp-image.sh",
    "cursor:mcp:playwright": "bash ./scripts/mcp-playwright.sh",
    "cursor:mcp:context7": "bash ./scripts/mcp-context7.sh",
    "verify:android": "npm run android:prepare && ./gradlew :app:assembleDebug :feature-ai:testDebugUnitTest :app:lintDebug :app:detekt :feature-ai:detekt --no-daemon",
    "verify:functions": "cd functions && npm ci && npm run build && npm run lint && npm test",
    "verify": "npm run verify:android && npm run verify:functions && npm run format:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patlar104/novachat.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/patlar104/novachat/issues"
  },
  "homepage": "https://github.com/patlar104/novachat#readme",
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@dataconnect/generated": "file:generated/dataconnect/js-client"
  }
}
